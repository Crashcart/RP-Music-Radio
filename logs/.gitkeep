# This directory holds log files generated by AetherWave install/update/uninstall
# scripts and the centralized logging system (scripts/lib/log.sh).
#
# Logs follow the naming convention:
#   <script-name>-<YYYYMMDD-HHMMSS>.log
#
# Use these tools to manage them:
#   ./scripts/logs.sh list          # List all logs
#   ./scripts/logs.sh tail <script> # Tail latest log for a script
#   ./scripts/logs.sh errors        # Show errors across all logs
#   ./scripts/logs.sh clean         # Remove logs older than 30 days
#   ./scripts/troubleshoot.sh       # Run diagnostic checks
