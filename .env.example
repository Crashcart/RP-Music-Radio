# Google Cloud API
GOOGLE_API_KEY=your-api-key-here

# Hardware Configuration
# Options: INTEL_QUICKSYNC, NVIDIA_CUDA, CPU_ONLY
DEVICE_TYPE=INTEL_QUICKSYNC

# MP3 Naming Convention
AUTO_NAME_FORMAT={STATION}_{ARTIST}_{TRACK}.mp3

# Feature Flags
FILLER_ENABLED=true

# Redis & Database URLs
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:////app/data/aetherwave.db

# Logging
LOG_LEVEL=info

# API Configuration
API_PORT=8433
API_HOST=0.0.0.0

# AI Service Configuration
# OLLAMA_ENABLED: Use local Ollama instance (default: true)
# OLLAMA_AUTO_FALLBACK: Automatically switch to Gemini if Ollama goes down (default: true)
# OLLAMA_HOST: Ollama API endpoint (default: http://localhost:11434)
# OLLAMA_MODEL: Model to use with Ollama (default: mistral)
# AI_PREFER_CLOUD: Prefer Gemini over Ollama (default: false)
OLLAMA_ENABLED=true
OLLAMA_AUTO_FALLBACK=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
AI_PREFER_CLOUD=false
